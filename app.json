{
  "expo": {
    "name": "ReceiptSnap",
    "slug": "ReceiptSnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.receiptsnap.internal",
      "infoPlist": {
        "NSCameraUsageDescription": "ReceiptSnap needs camera access to photograph receipts.",
        "NSPhotoLibraryUsageDescription": "ReceiptSnap needs photo library access to import receipt images.",
        "NSPhotoLibraryAddUsageDescription": "ReceiptSnap saves receipt images to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "package": "com.receiptsnap.internal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ad9c6460-a134-47d5-ba3c-07b438e679e8"
      }
    },
    "owner": "bethlehem1989"
  }
}
